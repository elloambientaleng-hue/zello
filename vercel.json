{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "painel.zelloambiental.com.br"
        }
      ],
      "destination": "/painel.html"
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "portal.zelloambiental.com.br"
        }
      ],
      "destination": "/cliente.html"
    }
  ],
  "redirects": [
    {
      "source": "/cliente",
      "destination": "/cliente.html",
      "permanent": false
    },
    {
      "source": "/painel",
      "destination": "/painel.html",
      "permanent": false
    }
  ]
}